generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String?
  image         String?
  analysisCount Int      @default(0)
  createdAt     DateTime @default(now())
}
